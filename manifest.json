{
  "manifest_version": 3,
  "name": "AI Vision",
  "version": "2.0.0",
  "description": "AI chat with screen capture, page summarizer, history & more — powered by Groq",
  "permissions": [
    "storage", "tabs", "activeTab", "scripting", "desktopCapture", "contextMenus"
  ],
  "host_permissions": ["https://api.groq.com/*", "<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
  },
  "background": { "service_worker": "background.js" },
  "content_scripts": [{ "matches": ["<all_urls>"], "js": ["content.js"], "all_frames": false }],
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Ctrl+Shift+A", "mac": "Command+Shift+A" },
      "description": "Open AI Vision"
    }
  },
  "web_accessible_resources": [{ "resources": ["floating.js", "floating.css"], "matches": ["<all_urls>"] }],
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
}
