{
  "manifest_version": 3,
  "name": "Groq Vision AI",
  "version": "1.0.0",
  "description": "AI chat assistant with screen capture powered by Groq",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "desktopCapture"
  ],
  "host_permissions": [
    "https://api.groq.com/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["capture.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
